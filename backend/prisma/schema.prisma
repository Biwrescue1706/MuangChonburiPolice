generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  adminId   String    @id @default(uuid())
  username  String    @unique
  password  String
  name      String
  position  String
  createdAt DateTime  @default(now())
  updatedAt DateTime?
}

model OrganizationCommander {
  commanderId      String       @id @default(uuid())
  organizationId   String       @unique
  rank             String?
  fullRank         String?
  firstName        String?
  lastName         String?
  fullName         String?
  fullNameWithRank String?
  position         String?
  fullPosition     String?
  signatureImage   String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime?
  organization     Organization @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
}

model OrganizationFinance {
  financeId        String       @id @default(uuid())
  organizationId   String       @unique
  rank             String?
  firstName        String?
  lastName         String?
  fullName         String?
  fullNameWithRank String?
  position         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime?
  organization     Organization @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
}

model Organization {
  organizationId   String                 @id @default(uuid())
  key              String                 @unique @default("MAIN")
  organizationName String
  rank             String?
  firstName        String
  lastName         String
  fullName         String
  fullNameWithRank String
  position         String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime?
  commander        OrganizationCommander?
  finance          OrganizationFinance?
  persons          Person[]
  receipts         Receipt[]
}

model Person {
  personId                  String                     @id @default(uuid())
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime?
  prefix                    String
  firstName                 String
  lastName                  String
  fullName                  String
  citizenId                 String
  birthDate                 String?
  birthDay                  String?
  birthMonth                String?
  birthYear                 String?
  nationality               String?
  ethnicity                 String?
  weight                    Int?
  height                    Int?
  bodyType                  String?                    @default("สันทัด")
  skinColor                 String?                    @default("ดำแดง")
  behavior                  String?                    @default("ปกติ")
  distinguishingMarks       String?                    @default("-")
  address                   String?
  occupation                String?
  workplaceAddress          String?
  father                    String?
  mother                    String?
  spouse                    String?                    @default("-")
  fingerprintDate           String?
  purpose                   String?
  requestingAgency          String?
  receiptBookNo             String?
  receiptNo                 String?
  receiptDate               String?
  money                     Int                        @default(100)
  moneyText                 String?
  status                    Int                        @default(0)
  statusUpdatedAt           DateTime?
  deleteAt                  DateTime?
  organizationId            String?
  organizationName          String?
  fullNameOrg               String?
  rank                      String?
  position                  String?
  fullNameWithRank          String?
  priority                  Int                        @default(0)
  returnDate                DateTime?
  organization              Organization?              @relation(fields: [organizationId], references: [organizationId])
  receipts                  Receipt[]
  requestInfos              RequestInfo[]
  statusHistories           PersonStatusHistory[]
  forensicSubmissionPersons ForensicSubmissionPerson[]
}

model PersonStatusHistory {
  historyId String @id @default(uuid())

  personId String

  oldStatus Int
  newStatus Int

  changedAt DateTime @default(now())

  person Person @relation(fields: [personId], references: [personId], onDelete: Cascade)

  @@index([personId])
  @@index([oldStatus, newStatus])
  @@index([changedAt])
}

model RequestInfo {
  requestInfoId    String   @id @default(uuid())
  personId         String
  purpose          String?
  requestingAgency String?
  createdAt        DateTime @default(now())
  person           Person   @relation(fields: [personId], references: [personId], onDelete: Cascade)
}

model Receipt {
  receiptId        String        @id @default(uuid())
  personId         String?
  prefix           String
  firstName        String
  lastName         String
  fullName         String
  organizationId   String?
  organizationName String?
  fullNameOrg      String?
  rank             String?
  position         String?
  fullNameWithRank String?
  receiptBookNo    String?
  receiptNo        String?
  receiptDate      String?
  money            Int
  moneyText        String?
  createdAt        DateTime      @default(now())
  priority         Int           @default(0)
  organization     Organization? @relation(fields: [organizationId], references: [organizationId])
  person           Person?       @relation(fields: [personId], references: [personId], onDelete: Cascade)
}

model ForensicSubmission {
  submissionId   String   @id @default(uuid())
  submissionNo   String?
  submissionDate DateTime @default(now())

  createdAt DateTime @default(now())

  persons ForensicSubmissionPerson[]
}

model ForensicSubmissionPerson {
  id String @id @default(uuid())

  submissionId String
  personId     String

  submission ForensicSubmission @relation(fields: [submissionId], references: [submissionId], onDelete: Cascade)

  person Person @relation(fields: [personId], references: [personId], onDelete: Cascade)

  @@unique([submissionId, personId])
}
