generator client {
  provider = "prisma-client-js" // สร้าง Prisma Client
}

datasource db {
  provider  = "postgresql" // ใช้ฐานข้อมูล PostgreSQL
  url       = env("DATABASE_URL") // connection หลัก
  directUrl = env("DIRECT_URL") // ใช้ตอน migrate
}

model Admin {
  id String @id @default(uuid()) // รหัสผู้ดูแลระบบ
  username String @unique // ชื่อเข้าสู่ระบบ
  password String // รหัสผ่านแบบเข้ารหัส
  name String // ชื่อผู้ดูแล
  position String // ตำแหน่งงาน
  createdAt DateTime @default(now()) // วันที่สร้างบัญชี
  updatedAt DateTime? // วันที่แก้ไขล่าสุด
}

model Person {
  id String @id @default(uuid()) // รหัสบุคคล
  createdAt DateTime @default(now()) // วันที่บันทึกข้อมูล

  prefix String // คำนำหน้าชื่อ
  firstName String // ชื่อจริง
  lastName String // นามสกุล
  fullName String // ชื่อเต็ม

  citizenId String @unique // เลขบัตรประชาชน

  birthDate DateTime? // วันเกิดเต็ม
  birthDay Int? // วันเกิด
  birthMonth Int? // เดือนเกิด
  birthYear Int? // ปีเกิด

  nationality String? // สัญชาติ
  ethnicity String? // เชื้อชาติ

  weight Int? // น้ำหนัก
  height Int? // ส่วนสูง

  distinguishingMarks String? // ตำหนิร่างกาย

  address String? // ที่อยู่
  occupation String? // อาชีพ
  workplaceAddress String? // ที่ทำงาน

  father String? // ชื่อบิดา
  mother String? // ชื่อมารดา
  spouse String? @default("-") // คู่สมรส

  updatedAt DateTime? // วันที่แก้ไขข้อมูล

  requests VerificationRequest[] // รายการคำร้องของบุคคล
}

model Organization {
  id String @id @default(uuid()) // รหัสองค์กร
  key String @unique @default("MAIN") // key องค์กร
  organizationName String // ชื่อองค์กร

  rank String? // ยศผู้ลงนาม
  firstName String // ชื่อผู้ลงนาม
  lastName String // นามสกุลผู้ลงนาม

  fullName String // ชื่อเต็ม
  fullNameWithRank String // ชื่อพร้อมยศ
  position String // ตำแหน่ง

  createdAt DateTime @default(now()) // วันที่สร้าง
  updatedAt DateTime? // วันที่แก้ไข

  requests VerificationRequest[] // คำร้องขององค์กร
}

model VerificationRequest {
  id String @id @default(uuid()) // รหัสคำร้อง

  personId String // อ้างอิงบุคคล
  person Person @relation(fields: [personId], references: [id]) // บุคคลที่ถูกตรวจ

  organizationId String? // อ้างอิงองค์กร
  organization Organization? @relation(fields: [organizationId], references: [id]) // องค์กรผู้ร้อง

  files VerificationFile[] // ไฟล์เอกสารคำร้อง

  purpose String? // วัตถุประสงค์
  requestingAgency String? // หน่วยงานที่ขอ

  receiptBookNo String? // เล่มใบเสร็จ
  receiptNo String? // เลขใบเสร็จ

  receiptDate DateTime? // วันที่ใบเสร็จ
  submittedDate DateTime? // วันที่ยื่นคำร้อง

  status Int @default(0) // สถานะคำร้อง

  expireAt DateTime // วันหมดอายุ
  createdAt DateTime @default(now()) // วันที่สร้าง
  updatedAt DateTime? // วันที่แก้ไข
}

model VerificationFile {
  id String @id @default(uuid()) // รหัสไฟล์

  requestId String // อ้างอิงคำร้อง
  request VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade) // เจ้าของไฟล์

  filePath String // ที่อยู่ไฟล์
  fileName String // ชื่อไฟล์

  createdAt DateTime @default(now()) // วันที่อัปโหลด
  updatedAt DateTime? // วันที่แก้ไข
}