generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ADMIN
model Admin {
  adminId   String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  position  String
  createdAt DateTime @default(now())
  updatedAt DateTime?
}

// ORGANIZATION
model Organization {
  organizationId   String @id @default(uuid())
  key              String @unique @default("MAIN")
  organizationName String

  rank             String?
  firstName        String
  lastName         String
  fullName         String
  fullNameWithRank String
  position         String

  createdAt DateTime @default(now())
  updatedAt DateTime?

  receipts Receipt[]
persons Person[]
}

// PERSON
model Person {
  personId  String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime?

  prefix    String
  firstName String
  lastName  String
  fullName  String
  citizenId String @unique

  birthDate  String?
  birthDay   String?
  birthMonth String?
  birthYear  String?

  nationality String?
  ethnicity   String?

  weight              Int?
  height              Int?
  bodyType            String? @default("สันทัด")
  skinColor           String? @default("ดำแดง")
  behavior            String? @default("ปกติ")
  distinguishingMarks String?

  address          String?
  occupation       String?
  workplaceAddress String?
  father           String?
  mother           String?
  spouse           String? @default("-")

  fingerprintDate String?

  purpose          String?
  requestingAgency String?

  receiptBookNo String?
  receiptNo     String?
  receiptDate   String?
  money         Int     @default(100)
  moneyText     String?

  status Int @default(0)
  statusUpdatedAt DateTime?

  deleteAt DateTime?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [organizationId])

  organizationName String?
  fullNameOrg      String?
  rank             String?
  position         String?
  fullNameWithRank String?

  files                PersonFile[]
  nationalitySnapshot  NationalitySnapshot[]
  ethnicitySnapshot    EthnicitySnapshot[]
  skinColorSnapshot    SkinColorSnapshot[]
  bodyTypeSnapshot     BodyTypeSnapshot[]
  requestInfos         RequestInfo[]
  receipts             Receipt[]
}

model PersonFile {
  fileId   String @id @default(uuid())
  personId String
  person   Person @relation(fields: [personId], references: [personId], onDelete: Cascade)

  fileName String
  filePath String
  fileSize Int?
  mimeType String @default("application/pdf")

  createdAt DateTime @default(now())
}

model NationalitySnapshot {
  nationalityId String @id @default(uuid())

  personId String
  person   Person @relation(fields: [personId], references: [personId])

  nationality String?
  createdAt   DateTime @default(now())
}

model EthnicitySnapshot {
  ethnicityId String @id @default(uuid())

  personId String
  person   Person @relation(fields: [personId], references: [personId])

  ethnicity String?
  createdAt DateTime @default(now())
}

model BodyTypeSnapshot {
  bodyTypeId String @id @default(uuid())

  personId String
  person   Person @relation(fields: [personId], references: [personId])

  bodyType  String?
  createdAt DateTime @default(now())
}

model SkinColorSnapshot {
  skinColorId String @id @default(uuid())

  personId String
  person   Person @relation(fields: [personId], references: [personId])

  skinColor String?
  createdAt DateTime @default(now())
}

model RequestInfo {
  requestInfoId String @id @default(uuid())

  personId String
  person   Person @relation(fields: [personId], references: [personId])

  purpose          String?
  requestingAgency String?

  createdAt DateTime @default(now())
}

// =======================
// RECEIPT (สำคัญ)
// =======================
model Receipt {
  receiptId String @id @default(uuid())

  personId String
  person   Person @relation(fields: [personId], references: [personId])

  // ✅ snapshot PERSON
  prefix    String
  firstName String
  lastName  String
  fullName  String

  // ✅ snapshot ORGANIZATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [organizationId])

  organizationName String?
  fullNameOrg      String?
  rank             String?
  position         String?
  fullNameWithRank String?

  receiptBookNo String?
  receiptNo     String?
  receiptDate   DateTime?
  money         Int
  moneyText     String?

  createdAt DateTime @default(now())
}