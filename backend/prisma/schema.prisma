generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//
// ADMIN
//
model Admin {
  id       String @id @default(uuid())
  username String @unique
  password String
  name     String
  position String

  createdAt DateTime @default(now())
updatedAt DateTime?
}

// PERSON
model Person {
  id String @id @default(uuid())

  createdAt DateTime @default(now()) // วันที่ทำรายการ (วันที่บันทึกข้อมูล)

  prefix    String   // คำนำหน้าชื่อ
  firstName String   // ชื่อ
  lastName  String   // นามสกุล
  fullName  String   // คำนำหน้า + ชื่อ + นามสกุล

  citizenId String @unique // เลขบัตรประชาชน

  birthDate DateTime? // วันเกิดเต็ม

  birthDay   Int? // วันเกิด
  birthMonth Int? // เดือนเกิด
  birthYear  Int? // ปีเกิด

  nationality String? // สัญชาติ
  ethnicity   String? // เชื้อชาติ

  weight Int? // น้ำหนัก (จำนวนเต็ม)
  height Int? // ส่วนสูง (จำนวนเต็ม)

  distinguishingMarks String? // ตำหนิ / บาดแผล

  address String? // ที่อยู่
  occupation String? // อาชีพ
  workplaceAddress String? // ที่อยู่ที่ทำงาน

  father String? // ชื่อบิดา
  mother String? // ชื่อมารดา
  spouse String? @default("-") // คู่สมรส (ไม่มีให้เป็น -)

updatedAt DateTime?

  requests VerificationRequest[]
}

// องค์กร
model Organization {
  id String @id @default(uuid())

  key String @unique @default("MAIN")

  organizationName String //ชื่อองค์กร

  rank String? //ยศ
  firstName String //ชื่อจริง
  lastName String //นามสกุล

  fullName String // รวมชื่อ-นาสกุล
  fullNameWithRank String //รวมยศชื่อสกุล
  position String //ตำแหน่ง

  createdAt DateTime @default(now())
  updatedAt DateTime?

  requests VerificationRequest[]
}

// REQUEST
model VerificationRequest {
  id String @id @default(uuid())

  personId String
  person Person @relation(fields: [personId], references: [id])

  purpose String? // วัตถุประสงค์ในการขอ

  requestingAgency String?
  // สถานประกอบการที่ขอ

  receiptBookNo String? // เลขที่เล่มใบเสร็จ
  receiptNo     String? // เลขใบเสร็จ

  receiptDate DateTime? // วันที่ออกเลข

  submittedDate DateTime? // วันที่ยื่นคำร้อง

  status Int @default(0)
  // 0 = รอดำเนินการส่งศพฐ
  // 1 = ส่งศพฐแล้ว รอรับจากศพฐ
  // 2 = รับจาก ศพฐ แล้ว
  // 3 = ส่งผลเรียบร้อยแล้ว

  expireAt DateTime
  createdAt DateTime @default(now())
updatedAt DateTime?
}

// FILE
model VerificationFile {
  id String @id @default(uuid())

  requestId String
  request   VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  filePath String
  fileName String

  createdAt DateTime @default(now())
updatedAt DateTime?
}
